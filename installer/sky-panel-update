#!/usr/bin/env bash
# Installed to /usr/local/bin/sky-panel-update by install.sh.
# Pulls the latest GitHub release, verifies checksums, swaps binaries in
# place, and restarts whichever Sky Panel services are present on this box.
set -euo pipefail

REPO="Notbangbang-dev/sky-panel"
INSTALL_DIR="/opt/sky-panel"
VERSION_FILE="${INSTALL_DIR}/VERSION"

log() { echo "==> $*"; }
fail() { echo "error: $*" >&2; exit 1; }

[[ "$(id -u)" -eq 0 ]] || fail "must be run as root (try: sudo sky-panel-update)"
[[ -d "$INSTALL_DIR" ]] || fail "sky-panel does not appear to be installed at ${INSTALL_DIR}"

detect_arch() {
  case "$(uname -m)" in
    x86_64|amd64) echo "amd64" ;;
    aarch64|arm64) echo "arm64" ;;
    *) fail "unsupported architecture: $(uname -m)" ;;
  esac
}

current_version() {
  [[ -f "$VERSION_FILE" ]] && cat "$VERSION_FILE" || echo "unknown"
}

latest_release_tag() {
  curl -fsSL "https://api.github.com/repos/${REPO}/releases/latest" \
    | grep -m1 '"tag_name"' \
    | sed -E 's/.*"tag_name": *"([^"]+)".*/\1/'
}

ARCH="$(detect_arch)"
CURRENT="$(current_version)"
LATEST="$(latest_release_tag)"

[[ -n "$LATEST" ]] || fail "could not reach GitHub to check for a new release"

if [[ "$CURRENT" == "$LATEST" ]]; then
  log "already up to date (${CURRENT})"
  exit 0
fi

log "updating sky-panel: ${CURRENT} -> ${LATEST}"

WORKDIR="$(mktemp -d)"
trap 'rm -rf "$WORKDIR"' EXIT

BASE_URL="https://github.com/${REPO}/releases/download/${LATEST}"
curl -fsSL "${BASE_URL}/checksums.txt" -o "${WORKDIR}/checksums.txt"

download_and_verify() {
  local asset="$1" dest="$2"
  curl -fsSL "${BASE_URL}/${asset}" -o "$dest"
  ( cd "$(dirname "$dest")" && grep " ${asset}\$" "${WORKDIR}/checksums.txt" | sha256sum -c - ) \
    || fail "checksum verification failed for ${asset}"
}

stop_if_active() {
  systemctl is-active --quiet "$1" && systemctl stop "$1" || true
}

start_if_enabled() {
  systemctl is-enabled --quiet "$1" 2>/dev/null && systemctl start "$1" || true
}

# panel-api is always present on a panel install.
if [[ -f "${INSTALL_DIR}/bin/panel-api" ]]; then
  log "fetching panel-api"
  download_and_verify "panel-api-linux-${ARCH}" "${WORKDIR}/panel-api"

  log "fetching web assets"
  download_and_verify "web-dist.tar.gz" "${WORKDIR}/web-dist.tar.gz"

  stop_if_active sky-panel

  cp "${INSTALL_DIR}/bin/panel-api" "${INSTALL_DIR}/bin/panel-api.bak"
  install -m 755 "${WORKDIR}/panel-api" "${INSTALL_DIR}/bin/panel-api"

  rm -rf "${INSTALL_DIR}/web.new"
  mkdir -p "${INSTALL_DIR}/web.new"
  tar -xzf "${WORKDIR}/web-dist.tar.gz" -C "${INSTALL_DIR}/web.new"
  rm -rf "${INSTALL_DIR}/web.bak"
  mv "${INSTALL_DIR}/web" "${INSTALL_DIR}/web.bak"
  mv "${INSTALL_DIR}/web.new" "${INSTALL_DIR}/web"

  start_if_enabled sky-panel
fi

# node-agent is only present on a node install.
if [[ -f "${INSTALL_DIR}/bin/node-agent" ]]; then
  log "fetching node-agent"
  download_and_verify "node-agent-linux-${ARCH}" "${WORKDIR}/node-agent"
  log "fetching skyperf"
  download_and_verify "skyperf-linux-${ARCH}" "${WORKDIR}/skyperf"

  stop_if_active sky-node-agent

  cp "${INSTALL_DIR}/bin/node-agent" "${INSTALL_DIR}/bin/node-agent.bak"
  install -m 755 "${WORKDIR}/node-agent" "${INSTALL_DIR}/bin/node-agent"
  cp "${INSTALL_DIR}/bin/skyperf" "${INSTALL_DIR}/bin/skyperf.bak"
  install -m 755 "${WORKDIR}/skyperf" "${INSTALL_DIR}/bin/skyperf"

  start_if_enabled sky-node-agent
fi

echo "$LATEST" > "$VERSION_FILE"
log "updated to ${LATEST}"

echo
echo "--- changelog ---"
curl -fsSL "https://raw.githubusercontent.com/${REPO}/main/CHANGELOG.md" \
  | awk "/^## \[/{if (seen) exit; seen=1} seen" \
  || echo "(could not fetch changelog — see https://github.com/${REPO}/releases/tag/${LATEST})"
