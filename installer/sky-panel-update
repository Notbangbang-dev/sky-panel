#!/usr/bin/env bash
# Installed to /usr/local/bin/sky-panel-update by install.sh.
# panel-api/web and sky-daemon are separate GitHub releases with independent
# version cadence, so each is checked, downloaded and swapped in place on its
# own — a box running only "panel" or only "node" simply has nothing to do
# for the other half.
set -euo pipefail

REPO="Notbangbang-dev/sky-panel"
DAEMON_REPO="Notbangbang-dev/sky-daemon"
INSTALL_DIR="/opt/sky-panel"

log() { echo "==> $*"; }
fail() { echo "error: $*" >&2; exit 1; }

[[ "$(id -u)" -eq 0 ]] || fail "must be run as root (try: sudo sky-panel-update)"
[[ -d "$INSTALL_DIR" ]] || fail "sky-panel does not appear to be installed at ${INSTALL_DIR}"

detect_arch() {
  case "$(uname -m)" in
    x86_64|amd64) echo "amd64" ;;
    aarch64|arm64) echo "arm64" ;;
    *) fail "unsupported architecture: $(uname -m)" ;;
  esac
}

current_version() {
  local file="$1"
  [[ -f "$file" ]] && cat "$file" || echo "unknown"
}

latest_release_tag() {
  local repo="$1"
  curl -fsSL "https://api.github.com/repos/${repo}/releases/latest" \
    | grep -m1 '"tag_name"' \
    | sed -E 's/.*"tag_name": *"([^"]+)".*/\1/'
}

stop_if_active() {
  systemctl is-active --quiet "$1" && systemctl stop "$1" || true
}

start_if_enabled() {
  systemctl is-enabled --quiet "$1" 2>/dev/null && systemctl start "$1" || true
}

# Print the top (most recent) section of a repo's CHANGELOG.md. The body is
# captured into a variable first rather than piped straight into awk: piping
# `curl | awk '... exit'` makes awk close the pipe early, so curl dies with
# SIGPIPE (exit 23) and, under `set -o pipefail`, the whole pipeline "fails" —
# printing a spurious "could not fetch" even though the changelog printed fine.
print_changelog() {
  local repo="$1" tag="$2" body
  echo
  echo "--- ${repo##*/} changelog ---"
  if body="$(curl -fsSL "https://raw.githubusercontent.com/${repo}/main/CHANGELOG.md")"; then
    # here-string (no upstream process), so awk's early exit can't SIGPIPE anything.
    awk '/^## \[/{c++} c==2{exit} c==1' <<<"$body"
  else
    echo "(could not fetch changelog — see https://github.com/${repo}/releases/tag/${tag})"
  fi
}

ARCH="$(detect_arch)"
UPDATED_ANYTHING=0

# panel-api + web (Notbangbang-dev/sky-panel releases).
if [[ -f "${INSTALL_DIR}/bin/panel-api" ]]; then
  CURRENT="$(current_version "${INSTALL_DIR}/VERSION")"
  LATEST="$(latest_release_tag "$REPO")"
  [[ -n "$LATEST" ]] || fail "could not reach GitHub to check for a new sky-panel release"

  if [[ "$CURRENT" == "$LATEST" ]]; then
    log "panel-api/web already up to date (${CURRENT})"
  else
    log "updating panel-api/web: ${CURRENT} -> ${LATEST}"
    WORKDIR="$(mktemp -d)"
    BASE_URL="https://github.com/${REPO}/releases/download/${LATEST}"
    curl -fsSL "${BASE_URL}/checksums.txt" -o "${WORKDIR}/checksums.txt"

    download_and_verify() {
      local asset="$1" dest="$2"
      curl -fsSL "${BASE_URL}/${asset}" -o "$dest"
      # checksums.txt records hashes against the release asset's own name
      # (e.g. panel-api-linux-amd64), which usually differs from the local
      # filename we saved it as (e.g. panel-api) — rewrite the checksum
      # line to reference the local filename rather than renaming the
      # downloaded file to match, so sha256sum -c actually finds it.
      local expected
      expected="$(grep " ${asset}\$" "${WORKDIR}/checksums.txt" | awk '{print $1}')"
      [[ -n "$expected" ]] || fail "no checksum entry found for ${asset}"
      echo "${expected}  $(basename "$dest")" | ( cd "$(dirname "$dest")" && sha256sum -c - ) \
        || fail "checksum verification failed for ${asset}"
    }

    download_and_verify "panel-api-linux-${ARCH}" "${WORKDIR}/panel-api"
    download_and_verify "web-dist.tar.gz" "${WORKDIR}/web-dist.tar.gz"

    stop_if_active sky-panel

    cp "${INSTALL_DIR}/bin/panel-api" "${INSTALL_DIR}/bin/panel-api.bak"
    install -m 755 "${WORKDIR}/panel-api" "${INSTALL_DIR}/bin/panel-api"

    rm -rf "${INSTALL_DIR}/web.new"
    mkdir -p "${INSTALL_DIR}/web.new"
    tar -xzf "${WORKDIR}/web-dist.tar.gz" -C "${INSTALL_DIR}/web.new"
    rm -rf "${INSTALL_DIR}/web.bak"
    mv "${INSTALL_DIR}/web" "${INSTALL_DIR}/web.bak"
    mv "${INSTALL_DIR}/web.new" "${INSTALL_DIR}/web"

    start_if_enabled sky-panel
    rm -rf "$WORKDIR"

    echo "$LATEST" > "${INSTALL_DIR}/VERSION"
    log "panel-api/web updated to ${LATEST}"
    UPDATED_ANYTHING=1

    print_changelog "$REPO" "$LATEST"
  fi
fi

# sky-daemon (Notbangbang-dev/sky-daemon releases).
if [[ -f "${INSTALL_DIR}/bin/sky-daemon" ]]; then
  CURRENT="$(current_version "${INSTALL_DIR}/VERSION-daemon")"
  LATEST="$(latest_release_tag "$DAEMON_REPO")"
  [[ -n "$LATEST" ]] || fail "could not reach GitHub to check for a new sky-daemon release"

  if [[ "$CURRENT" == "$LATEST" ]]; then
    log "sky-daemon already up to date (${CURRENT})"
  else
    log "updating sky-daemon: ${CURRENT} -> ${LATEST}"
    WORKDIR="$(mktemp -d)"
    BASE_URL="https://github.com/${DAEMON_REPO}/releases/download/${LATEST}"
    curl -fsSL "${BASE_URL}/checksums.txt" -o "${WORKDIR}/checksums.txt"

    asset="sky-daemon-linux-${ARCH}"
    curl -fsSL "${BASE_URL}/${asset}" -o "${WORKDIR}/sky-daemon"
    expected="$(grep " ${asset}\$" "${WORKDIR}/checksums.txt" | awk '{print $1}')"
    [[ -n "$expected" ]] || fail "no checksum entry found for ${asset}"
    echo "${expected}  sky-daemon" | ( cd "$WORKDIR" && sha256sum -c - ) \
      || fail "checksum verification failed for ${asset}"

    stop_if_active sky-daemon

    cp "${INSTALL_DIR}/bin/sky-daemon" "${INSTALL_DIR}/bin/sky-daemon.bak"
    install -m 755 "${WORKDIR}/sky-daemon" "${INSTALL_DIR}/bin/sky-daemon"

    start_if_enabled sky-daemon
    rm -rf "$WORKDIR"

    echo "$LATEST" > "${INSTALL_DIR}/VERSION-daemon"
    log "sky-daemon updated to ${LATEST}"
    UPDATED_ANYTHING=1

    print_changelog "$DAEMON_REPO" "$LATEST"
  fi
fi

[[ "$UPDATED_ANYTHING" -eq 1 ]] || log "everything already up to date"
